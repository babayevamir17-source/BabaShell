{
  "func": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:param}) {",
      "    $0",
      "}"
    ],
    "description": "Creates a function"
  },
  "when": {
    "prefix": "when",
    "body": [
      "when #${1:id} clicked {",
      "    $0",
      "}"
    ],
    "description": "Event handler block"
  },
  "loop": {
    "prefix": "loop",
    "body": [
      "loop ${1:i} = ${2:1}..${3:10} {",
      "    $0",
      "}"
    ],
    "description": "Loop (for)"
  },
  "emit": {
    "prefix": "emit",
    "body": [
      "emit ${1:\"text\"}"
    ],
    "description": "Emit to console"
  },
  "whenClicked": {
    "prefix": "when clicked",
    "body": [
      "when #${1:id} clicked {",
      "    emit \"${2:text}\"",
      "}"
    ],
    "description": "When element clicked"
  },
  "whenHover": {
    "prefix": "when hover",
    "body": [
      "when #${1:id} hover {",
      "    set #${1:id} class \"${2:hovered}\"",
      "}"
    ],
    "description": "When element hovered"
  },
  "useFrom": {
    "prefix": "use from",
    "body": [
      "use from {./${1:index.html}}"
    ],
    "description": "Bind HTML file"
  },
  "setText": {
    "prefix": "set text",
    "body": [
      "set #${1:id} text \"${2:text}\""
    ],
    "description": "Set text of element"
  },
  "uiButton": {
    "prefix": "ui button",
    "body": [
      "ui.button \"#${1:id}\" \"${2:text}\""
    ],
    "description": "Create button"
  },
  "setAttr": {
    "prefix": "set attr",
    "body": [
      "set #${1:id} ${2:src} \"${3:value}\""
    ],
    "description": "Set any attribute (src, href, data-*)"
  },
  "storeVar": {
    "prefix": "store",
    "body": [
      "store ${1:name} = ${2:\"value\"}"
    ],
    "description": "Declare state variable"
  },
  "increaseBy": {
    "prefix": "increase",
    "body": [
      "increase ${1:score} by ${2:1}"
    ],
    "description": "Increase numeric variable"
  },
  "ifElse": {
    "prefix": "if",
    "body": [
      "if ${1:condition} {",
      "    $2",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "If/else condition block"
  },
  "whileLoop": {
    "prefix": "while",
    "body": [
      "while ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "While loop"
  },
  "breakLoop": {
    "prefix": "break",
    "body": [
      "break"
    ],
    "description": "Break out of the current loop"
  },
  "continueLoop": {
    "prefix": "continue",
    "body": [
      "continue"
    ],
    "description": "Continue with the next loop iteration"
  },
  "elseIf": {
    "prefix": "else if",
    "body": [
      "else if ${1:condition} {",
      "    $0",
      "}"
    ],
    "description": "Else-if condition block"
  },
  "repeatTimes": {
    "prefix": "repeat",
    "body": [
      "repeat ${1:5} times {",
      "    $0",
      "}"
    ],
    "description": "Repeat block N times"
  },
  "forIn": {
    "prefix": "for in",
    "body": [
      "for ${1:item} in ${2:list} {",
      "    $0",
      "}"
    ],
    "description": "For-each loop"
  },
  "waitBlock": {
    "prefix": "wait",
    "body": [
      "wait ${1:2s} {",
      "    $0",
      "}"
    ],
    "description": "Delay execution"
  },
  "fetchAs": {
    "prefix": "fetch",
    "body": [
      "fetch \"${1:https://api.example.com}\" as ${2:data} {",
      "    set #${3:output} text ${2:data}.${4:name}",
      "}"
    ],
    "description": "Fetch API and bind result"
  },
  "cssNamespace": {
    "prefix": "css namespace",
    "body": [
      "${1:style}.#${2:id}.${3:background-color}: ${4:red}"
    ],
    "description": "Apply CSS property using namespace syntax"
  },
  "discordWebhook": {
    "prefix": "discord webhook",
    "body": [
      "store ok = bot.discord_webhook_send(\"${1:https://discord.com/api/webhooks/...}\", \"${2:Hello from BabaShell}\")",
      "if ok {",
      "    emit \"sent\"",
      "} else {",
      "    emit \"failed\"",
      "}"
    ],
    "description": "Send Discord message via webhook"
  },
  "httpGet": {
    "prefix": "http get",
    "body": [
      "store data = net.get(\"${1:https://api.example.com}\")",
      "emit data"
    ],
    "description": "HTTP GET helper"
  },
  "inputPrompt": {
    "prefix": "input",
    "body": [
      "store ${1:name} = input(\"${2:What is your name? }\")"
    ],
    "description": "Prompt the user for text input"
  },
  "confirmPrompt": {
    "prefix": "confirm",
    "body": [
      "if confirm(\"${1:Continue?}\") {",
      "    $0",
      "}"
    ],
    "description": "Prompt the user for confirmation"
  }
}
