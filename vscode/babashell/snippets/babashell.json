{
  "func": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:param}) {",
      "    $0",
      "}"
    ],
    "description": "Creates a function"
  },
  "when": {
    "prefix": "when",
    "body": [
      "when ${1:condition} {",
      "    $0",
      "} else {",
      "    ",
      "}"
    ],
    "description": "When/Else block"
  },
  "loop": {
    "prefix": "loop",
    "body": [
      "loop ${1:i} = ${2:1}..${3:10} {",
      "    $0",
      "}"
    ],
    "description": "Loop (for)"
  },
  "emit": {
    "prefix": "emit",
    "body": [
      "emit ${1:\"text\"}"
    ],
    "description": "Emit to console"
  },
  "whenClicked": {
    "prefix": "when clicked",
    "body": [
      "when #${1:id} clicked emit \"${2:text}\""
    ],
    "description": "When element clicked"
  },
  "useFrom": {
    "prefix": "use from",
    "body": [
      "use from {./${1:index.html}}"
    ],
    "description": "Bind HTML file"
  },
  "setText": {
    "prefix": "set text",
    "body": [
      "set #${1:id} text \"${2:text}\""
    ],
    "description": "Set text of element"
  },
  "uiButton": {
    "prefix": "ui button",
    "body": [
      "ui.button \"#${1:id}\" \"${2:text}\""
    ],
    "description": "Create button"
  },
  "setAttr": {
    "prefix": "set attr",
    "body": [
      "set #${1:id} ${2:src} \"${3:value}\""
    ],
    "description": "Set any attribute (src, href, data-*)"
  }
}
