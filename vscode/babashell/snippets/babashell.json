{
  "func": {
    "prefix": "func",
    "body": [
      "func ${1:name}(${2:param}) {",
      "    $0",
      "}"
    ],
    "description": "Creates a function"
  },
  "when": {
    "prefix": "when",
    "body": [
      "when ${1:condition} {",
      "    $0",
      "} else {",
      "    ",
      "}"
    ],
    "description": "When/Else block"
  },
  "loop": {
    "prefix": "loop",
    "body": [
      "loop ${1:i} = ${2:1}..${3:10} {",
      "    $0",
      "}"
    ],
    "description": "Loop (for)"
  },
  "emit": {
    "prefix": "emit",
    "body": [
      "emit ${1:\"text\"}"
    ],
    "description": "Emit to console"
  }
}
