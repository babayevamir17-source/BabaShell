{
    "$schema":  "https://json.schemastore.org/tmlanguage",
    "name":  "babashell",
    "scopeName":  "source.babashell",
    "patterns":  [
                     {
                         "include":  "#comments"
                     },
                     {
                         "include":  "#strings"
                     },
                     {
                         "include":  "#numbers"
                     },
                     {
                         "include":  "#selectors"
                     },
                     {
                         "include":  "#functionDecl"
                     },
                     {
                         "include":  "#keywords"
                     },
                     {
                         "include":  "#builtins"
                     }
                 ],
    "repository":  {
                       "comments":  {
                                        "patterns":  [
                                                         {
                                                             "name":  "comment.line.double-slash",
                                                             "match":  "//.*$"
                                                         }
                                                     ]
                                    },
                       "strings":  {
                                       "patterns":  [
                                                        {
                                                            "name":  "string.quoted.double",
                                                            "begin":  "\"",
                                                            "end":  "\"",
                                                            "patterns":  [
                                                                             {
                                                                                 "name":  "constant.character.escape",
                                                                                 "match":  "\\\\."
                                                                             }
                                                                         ]
                                                        }
                                                    ]
                                   },
                       "numbers":  {
                                       "patterns":  [
                                                        {
                                                            "name":  "constant.numeric",
                                                            "match":  "(?\u003c![\\w.])\\d+(?:\\.\\d+)?(?![\\w.])"
                                                        }
                                                    ]
                                   },
                       "selectors":  {
                                         "patterns":  [
                                                          {
                                                              "name":  "entity.other.attribute-name.id",
                                                              "match":  "#[A-Za-z_][A-Za-z0-9_-]*"
                                                          }
                                                      ]
                                     },
                       "functionDecl":  {
                                            "patterns":  [
                                                             {
                                                                 "name":  "meta.function",
                                                                 "match":  "\\bfunc\\s+([A-Za-z_][A-Za-z0-9_əğıöüıçşƏĞİÖÜÇŞ]*)",
                                                                 "captures":  {
                                                                                  "1":  {
                                                                                            "name":  "entity.name.function"
                                                                                        }
                                                                              }
                                                             }
                                                         ]
                                        },
                       "keywords":  {
                                        "patterns":  [
                                                         {
                                                             "name":  "keyword.control",
                                                             "match":  "\\b(store|increase|decrease|by|if|else|while|break|continue|emit|when|clicked|click|hover|mouseover|mouseenter|mouseleave|loop|repeat|times|for|in|func|call|return|wait|fetch|as|import|true|false|null|and|or|map|use|from|set|ui|serve|export|build)\\b"
                                                         }
                                                     ]
                                    },
                       "builtins":  {
                                        "patterns":  [
                                                         {
                                                             "name":  "meta.function-call",
                                                             "match":  "\\b(console)\\.(print)\\b",
                                                             "captures":  {
                                                                              "1":  {
                                                                                        "name":  "support.class"
                                                                                    },
                                                                              "2":  {
                                                                                        "name":  "support.function"
                                                                                    }
                                                                          }
                                                         },
                                                         {
                                                             "name":  "support.function",
                                                             "match":  "\\b(help|print|read|input|confirm|ask_number|choose|clear|random|length|size|type_of|parse_number|to_string|red|green|yellow|blue|lower|upper|trim|contains|starts_with|ends_with|replace|regex_is_match|split|join|slice|push|pop|shift|unshift|keys|values|has_key|file_read|file_write|file_append|file_exists|file_delete|file_copy|file_move|dir_exists|dir_make|dir_delete|dir_list|http_get|http_post_json|json_parse|json_stringify|discord_webhook_send|hash_sha256|hash_md5|base64_encode|base64_decode|now|unix_time|format_time)\\b"
                                                         }
                                                     ]
                                    }
                   }
}
