{
  "name": "BabaShell Light",
  "type": "light",
  "colors": {
    "editor.background": "#FFFFFF",
    "editor.foreground": "#1A1A1A"
  },
  "tokenColors": [
    { "scope": "comment.line.double-slash", "settings": { "foreground": "#6F7F6F", "fontStyle": "italic" } },
    { "scope": "string.quoted.double", "settings": { "foreground": "#B45309" } },
    { "scope": "constant.numeric", "settings": { "foreground": "#7C3AED" } },
    { "scope": "keyword.control", "settings": { "foreground": "#1D4ED8", "fontStyle": "bold" } },
    { "scope": "support.function", "settings": { "foreground": "#047857" } },
    { "scope": "entity.name.function", "settings": { "foreground": "#A16207" } },
    { "scope": "entity.other.attribute-name.id", "settings": { "foreground": "#BE185D" } }
  ]
}
